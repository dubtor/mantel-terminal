#!/bin/bash
# Mantel — Terminal Wrapper
# Usage:
#   mantel                              - Open in current directory
#   mantel /path/to/project             - Open in specific directory
#   mantel init                         - Initialize .mantel/ in current directory
#   mantel init --background-color "#1a56db" - Set background color
#   mantel init --icon ../favicon.png        - Set project icon
#   mantel init --name "My Project"          - Set project name
#   mantel init --force                      - Re-detect all fields (keeps explicitly set values)

SCRIPT_DIR="$(cd "$(dirname "$(readlink -f "$0" 2>/dev/null || realpath "$0" 2>/dev/null || echo "$0")")" && pwd)"

if [ "$1" = "init" ]; then
  shift
  PROJECT_DIR="."
  BG_COLOR=""
  ICON=""
  NAME=""
  FORCE=""

  while [ $# -gt 0 ]; do
    case "$1" in
      --background-color) BG_COLOR="$2"; shift 2 ;;
      --icon) ICON="$2"; shift 2 ;;
      --name) NAME="$2"; shift 2 ;;
      --dir) PROJECT_DIR="$2"; shift 2 ;;
      --force) FORCE="1"; shift ;;
      *) echo "Unknown option: $1"; exit 1 ;;
    esac
  done

  PROJECT_DIR="$(cd "$PROJECT_DIR" && pwd)"
  MANTEL_DIR="$PROJECT_DIR/.mantel"
  mkdir -p "$MANTEL_DIR"

  # Resolve icon path (stored as relative path in config.json)
  ICON_PATH=""
  if [ -n "$ICON" ]; then
    if [ ! -f "$ICON" ]; then
      echo "Error: Icon file '$ICON' not found"
      exit 1
    fi
    # Convert to path relative to project root
    ICON_ABS="$(cd "$(dirname "$ICON")" && pwd)/$(basename "$ICON")"
    ICON_PATH="${ICON_ABS#$PROJECT_DIR/}"
    echo "Icon set: $ICON_PATH"
  fi

  # Auto-detect icon if none provided and config doesn't already have one (or --force)
  if [ -z "$ICON_PATH" ]; then
    HAS_ICON="no"
    if [ -z "$FORCE" ]; then
      HAS_ICON=$(python3 -c "
import json
try:
    c = json.load(open('$MANTEL_DIR/config.json'))
    print('yes' if c.get('icon') else 'no')
except: print('no')
" 2>/dev/null)
    fi

    if [ "$HAS_ICON" = "no" ]; then
      ICON_NAMES="favicon favico logo icon app-icon appicon logo-icon brand"
      ICON_EXTS="png jpg jpeg gif webp svg ico"

      for name in $ICON_NAMES; do
        for ext in $ICON_EXTS; do
          MATCH=$(find "$PROJECT_DIR" -maxdepth 3 -name "${name}.${ext}" -not -path '*/node_modules/*' -not -path '*/.git/*' -not -path '*/.mantel/*' -print -quit 2>/dev/null)
          if [ -n "$MATCH" ]; then
            ICON_PATH="${MATCH#$PROJECT_DIR/}"
            echo "Auto-detected icon: $ICON_PATH"
            break 2
          fi
        done
      done
    fi
  fi

  # Build or update config.json
  CONFIG="$MANTEL_DIR/config.json"
  if [ -f "$CONFIG" ]; then
    # Merge with existing config
    EXISTING=$(cat "$CONFIG")
  else
    EXISTING="{}"
  fi

  # Use python3 to merge JSON (available on macOS)
  # Write existing config to temp file for python to read
  EXISTING_TMP="$CONFIG.existing"
  echo "$EXISTING" > "$EXISTING_TMP"

  BG_COLOR="$BG_COLOR" NAME="$NAME" ICON_PATH="$ICON_PATH" PROJECT_DIR="$PROJECT_DIR" \
  EXISTING_FILE="$EXISTING_TMP" FORCE="$FORCE" \
  python3 << 'PYEOF' > "$CONFIG.tmp"
import json, sys, os, re

config = json.loads(open(os.environ['EXISTING_FILE']).read())
bg_color = os.environ.get('BG_COLOR', '')
name = os.environ.get('NAME', '')
icon_path = os.environ.get('ICON_PATH', '')
project = os.environ['PROJECT_DIR']
force = os.environ.get('FORCE', '')

# With --force, clear fields not explicitly set so auto-detection re-runs
if force:
    if not bg_color: config.pop('backgroundColor', None)
    if not name: config.pop('name', None)
    if not icon_path: config.pop('icon', None)

if bg_color: config['backgroundColor'] = bg_color
if name: config['name'] = name
if icon_path: config['icon'] = icon_path

# Auto-detect backgroundColor if not set
if not config.get('backgroundColor') and not bg_color:
    detected_color = None
    # 1. Check PWA manifest (manifest.json, site.webmanifest)
    for mname in ['manifest.json', 'site.webmanifest']:
        for subdir in ['.', 'public', 'static', 'src']:
            mp = os.path.join(project, subdir, mname)
            if os.path.isfile(mp):
                try:
                    m = json.load(open(mp))
                    detected_color = m.get('theme_color') or m.get('background_color')
                    if detected_color: break
                except: pass
        if detected_color: break
    # 2. Check HTML files for <meta name="theme-color">
    if not detected_color:
        for hname in ['index.html', 'public/index.html', 'src/index.html']:
            hp = os.path.join(project, hname)
            if os.path.isfile(hp):
                try:
                    html = open(hp).read()
                    match = re.search(r'<meta[^>]*name=["\']theme-color["\'][^>]*content=["\'](#[0-9a-fA-F]{3,8})["\']', html)
                    if not match:
                        match = re.search(r'<meta[^>]*content=["\'](#[0-9a-fA-F]{3,8})["\'][^>]*name=["\']theme-color["\']', html)
                    if match:
                        detected_color = match.group(1)
                        break
                except: pass
    if detected_color:
        config['backgroundColor'] = detected_color
        print(f'Auto-detected color: {detected_color}', file=sys.stderr)

# Auto-detect name
if not config.get('name'):
    pkg = os.path.join(project, 'package.json')
    if os.path.isfile(pkg):
        try:
            pname = json.load(open(pkg)).get('name', '')
            if pname: config['name'] = pname
        except: pass
    if not config.get('name'):
        config['name'] = os.path.basename(project)

json.dump(config, sys.stdout, indent=2)
print()
PYEOF
  rm -f "$EXISTING_TMP"
  mv "$CONFIG.tmp" "$CONFIG"

  echo "Initialized: $MANTEL_DIR/"
  cat "$CONFIG"
  exit 0
fi

TARGET_DIR="${1:-.}"
TARGET_DIR="$(cd "$TARGET_DIR" 2>/dev/null && pwd)"

if [ -z "$TARGET_DIR" ]; then
  echo "Error: Directory '$1' not found"
  exit 1
fi

cd "$SCRIPT_DIR" && npm start -- "$TARGET_DIR" 2>/dev/null &
disown
